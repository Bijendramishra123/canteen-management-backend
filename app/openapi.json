        "properties": {
          "id": {
            "type": "integer",
            "title": "Id",
            "description": "Unique food item ID",
            "example": 1
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Name of the food item",
            "example": "Margherita Pizza"
          },
          "price": {
            "type": "number",
            "title": "Price",
            "description": "Price of the food item",
            "example": 12.99
          },
          "category": {
            "type": "string",
            "title": "Category",
            "description": "Food category",
            "example": "Pizza"
          },
          "image": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Image",
            "description": "Image URL",
            "example": "https://example.com/pizza.jpg"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description",
            "description": "Detailed description",
            "example": "Classic pizza with tomato sauce and mozzarella"
