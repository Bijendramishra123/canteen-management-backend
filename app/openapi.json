            "type": "string",
            "minLength": 1,
            "title": "Name",
            "description": "Name of the food item",
            "example": "Margherita Pizza"
          },
          "price": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Price",
            "description": "Price of the food item",
            "example": 12.99
          },
          "category": {
            "type": "string",
            "minLength": 1,
            "title": "Category",
            "description": "Food category",
            "example": "Pizza"
          },
          "image": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Image",
            "description": "Image URL",
            "example": "https://example.com/pizza.jpg"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
